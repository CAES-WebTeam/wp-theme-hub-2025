{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "caes-hub/person-courses",
  "version": "0.1.0",
  "title": "Person Courses",
  "category": "theme",
  "icon": "welcome-learn-more",
  "description": "Displays courses taught by the person, synced from Symplectic Elements.",
  "supports": {
    "anchor": true,
    "typography": {
      "lineHeight": true,
      "fontSize": true
    },
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true
    },
    "layout": {
      "default": {
        "type": "flex",
        "orientation": "vertical"
      }
    }
  },
  "attributes": {
    "anchor": {
      "type": "string",
      "default": ""
    },
    "showHeading": {
      "type": "boolean",
      "default": false
    },
    "headingLevel": {
      "type": "number",
      "default": 2
    },
    "headingFontSize": {
      "type": "string",
      "default": ""
    },
    "itemFontSize": {
      "type": "string",
      "default": ""
    }
  },
  "usesContext": [
    "caes-hub/user-feed/userId",
    "caes-hub/user-feed/user"
  ],
  "render": "file:./render.php",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}