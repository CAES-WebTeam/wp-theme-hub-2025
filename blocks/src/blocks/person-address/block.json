{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "caes-hub/person-address",
    "version": "0.1.0",
    "title": "Person Address",
    "category": "theme",
    "icon": "location",
    "description": "Displays the person's mailing or shipping address from the personnel info section.",
    "acf": {
        "mode": "preview",
        "renderTemplate": "./render.php"
    },
    "supports": {
        "anchor": true,
        "typography": {
            "lineHeight": true,
            "fontSize": true
        },
        "color": {
            "background": true,
            "text": true
        },
        "spacing": {
            "padding": true,
            "margin": true,
            "blockGap": true
        },
        "layout": {
            "default": {
                "type": "flex",
                "orientation": "vertical"
            }
        }
    },
    "attributes": {
        "addressType": {
            "type": "string",
            "default": "mailing"
        },
        "showHeading": {
            "type": "boolean",
            "default": false
        },
        "headingLevel": {
            "type": "number",
            "default": 2
        },
        "headingFontSize": {
            "type": "string",
            "default": ""
        },
        "contentFontSize": {
            "type": "string",
            "default": ""
        }
    },
    "usesContext": [
        "caes-hub/user-feed/userId",
        "caes-hub/user-feed/user"
    ],
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css"
}
