{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "caes-hub/event-block",
  "version": "0.1.0",
  "title": "Event Block",
  "category": "theme",
  "icon": "calendar-alt",
  "description": "Event block for the CAES Field Report 2025 theme.",
  "render": "file:./render.php",
  "supports": {
    "anchor": true,
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "padding": true
    }
  },
  "attributes": {
    "eventRange": {
      "type": "string",
      "default": ""
    },
    "series": {
      "type": "number",
      "default": 0
    },
    "events": {
      "type": "array",
      "default": []
    },
    "numberOfPosts": {
      "type": "number",
      "default": 4
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}
